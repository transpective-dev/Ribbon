{
  "name": "mood-core",
  "version": "0.0.1-beta",
  "type": "module",
  "description": "A safe CLI. Protect you from unexpected executing.",
  "main": "./src/logics/index.ts",
  "bin": {
    "rib": "./launcher/launcher.ts"
  },
  "scripts": {
    "asbuild:debug": "asc assembly/index.ts --target debug",
    "asbuild:release": "asc assembly/index.ts --target release",
    "asbuild": "npm run asbuild:debug && npm run asbuild:release",
    "test": "node --test",
    "start": "npx serve ."
  },
  "author": "Transpective_dev_team",
  "license": "MIT",
  "dependencies": {
    "app-root-path": "3.1.0",
    "chalk": "5.6.2",
    "cli-table3": "0.6.5",
    "clipboardy": "^5.3.1",
    "commander": "14.0.3",
    "conf": "^15.1.0",
    "crypto-js": "^4.2.0",
    "enquirer": "2.4.1",
    "fs-extra": "11.3.4",
    "iconv-lite": "0.7.2",
    "keytar": "^7.9.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/fs-extra": "11.0.4",
    "@types/node": "25.6.0",
    "@types/prompts": "^2.4.9",
    "assemblyscript": "^0.28.17",
    "typescript": "6.0.2"
  },
  "exports": {
    ".": {
      "import": "./build/release.js",
      "types": "./build/release.d.ts"
    }
  }
}
